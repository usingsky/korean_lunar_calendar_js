{
  "name": "korean-lunar-calendar",
  "version": "0.4.0",
  "description": "library to convert Korean lunar-calendar to Gregorian",
  "keywords": [
    "calendar",
    "korean",
    "lunar",
    "solar",
    "달력",
    "양력",
    "음력",
    "한국"
  ],
  "homepage": "https://github.com/usingsky/korean_lunar_calendar_js#readme",
  "bugs": {
    "url": "https://github.com/usingsky/korean_lunar_calendar_js/issues"
  },
  "license": "MIT",
  "author": "Jinil Lee <usingsky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/usingsky/korean_lunar_calendar_js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/korean-lunar-calendar.js",
  "module": "./dist/korean-lunar-calendar.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/korean-lunar-calendar.min.js",
  "jsdelivr": "./dist/korean-lunar-calendar.min.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/korean-lunar-calendar.mjs",
      "require": "./dist/korean-lunar-calendar.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && vite build && vite build --config vite.config.browser.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "check": "oxlint && oxfmt --check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.8",
    "@types/node": "^24.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "rimraf": "^5.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">= 16.14.0"
  }
}
