{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "endOfLine": "lf",
  "ignorePatterns": [
    "dist",
    "node_modules",
    "docs",
    "other_lang",
    "jest.config.js",
    "test/dataset",
    "**/*.md"
  ]
}
